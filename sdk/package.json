{
  "name": "@axnic/pi-extension-settings-sdk",
  "version": "0.0.0",
  "description": "Type-safe SDK for interacting with the pi-extension-settings panel (for extension authors).",
  "author": "axnic",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/axnic/pi-extension-settings.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/axnic/pi-extension-settings#readme",
  "bugs": {
    "url": "https://github.com/axnic/pi-extension-settings/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "settings",
    "sdk",
    "extension",
    "type-safe"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm test && node ../scripts/prepare-publish-readmes.mjs prepare:sdk",
    "postpublish": "node ../scripts/prepare-publish-readmes.mjs restore:sdk"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "memfs": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
