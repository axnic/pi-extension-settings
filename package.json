{
  "name": "@axnic/pi-extension-settings",
  "version": "0.0.0",
  "description": "Centralized settings panel for pi extensions.",
  "author": "axnic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axnic/pi-extension-settings.git"
  },
  "homepage": "https://github.com/axnic/pi-extension-settings#readme",
  "bugs": {
    "url": "https://github.com/axnic/pi-extension-settings/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "settings",
    "configuration",
    "extension"
  ],
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "mise run build",
    "build:extension": "node build.mjs",
    "build:sdk": "pnpm --filter @axnic/pi-extension-settings-sdk run build",
    "build:all": "pnpm run build:extension && pnpm run build:sdk",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build:all && pnpm test && node scripts/prepare-publish-readmes.mjs prepare:extension",
    "postpublish": "node scripts/prepare-publish-readmes.mjs restore:extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "mise run lint",
    "lint:fix": "mise run lint:fix"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/types": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "rimraf": "catalog:",
    "trunk": "latest",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
