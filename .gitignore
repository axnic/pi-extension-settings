# =============================================================================
# Node.js / npm
# =============================================================================

node_modules/

# Debug logs produced by npm and Yarn on install/run failures
npm-debug.log
yarn-error.log

# Generic log / temp / backup / swap files (editor and tool artefacts)
*.log
*.bak
*.tmp
*.swp
*~

# =============================================================================
# Build output
# =============================================================================

# Extension compiled output (generated by `npm run build` / `mise run build:extension`)
# During local development, pi loads .ts files directly — no build needed.
# The dist/ is produced for distribution and production deployments.
/dist/

# Guard against build artifacts accidentally emitted into src/ when running
# `mise run build:sdk` before the extension is compiled (stray .js / .d.ts).
src/**/*.js
src/**/*.d.ts
src/**/*.d.ts.map

# SDK compiled output (generated by `npm run build:sdk` / `mise run build:sdk`)
sdk/dist/

# Test coverage reports (generated by vitest --coverage)
coverage/

# Generic cache directories (Vite, esbuild, etc.)
.cache/

# =============================================================================
# Environment / secrets
#
# This project stores no secrets (storage.ts uses plain JSON), but ignore env
# files as a safety net against accidental secret commits.
# =============================================================================

.env
.env.local
.env.*.local

# =============================================================================
# OS
# =============================================================================

# macOS Finder metadata
.DS_Store

# Windows Explorer thumbnails
Thumbs.db

# =============================================================================
# Editors and IDEs
# =============================================================================

# --- VS Code ---
# Ignore all workspace config except the files that are useful to share:
#   settings.json  — formatter, tab size, etc.
#   tasks.json     — build/test tasks surfaced in the UI
#   launch.json    — debugger configurations
#   extensions.json — recommended extensions for the project
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- JetBrains (IntelliJ, WebStorm, Rider, Android Studio, …) ---
# .idea/ contains workspace-local state; only .idea/*.xml shared configs are
# sometimes committed, but we keep it simple and ignore the whole directory.
.idea/

# --- Sublime Text ---
*.sublime-workspace
*.sublime-project

# =============================================================================
# AI / LLM agent instructions
#
# AGENTS.md (repo root) and .agents/ are the single canonical source of context
# for AI coding agents. All tool-specific instruction files are ignored so that
# agents receive one consistent set of instructions regardless of which tool is
# being used.
#
# To add or update agent instructions, edit AGENTS.md or place files under
# .agents/ — do NOT restore the tool-specific files below.
# =============================================================================

# --- Claude (Anthropic) ---
# CLAUDE.md          — Claude Code project instructions  (→ use AGENTS.md)
# .claude/           — Claude Code local session state and settings
CLAUDE.md
.claude/

# --- GitHub Copilot ---
# .github/copilot-instructions.md — Copilot custom instructions  (→ use AGENTS.md)
.github/copilot-instructions.md

# --- Cursor ---
# .cursorrules       — legacy single-file rules
# .cursor/           — directory-based rules (Cursor ≥ 0.43)
.cursorrules
.cursorignore
.cursor/

# --- Windsurf (Codeium) ---
# .windsurfrules     — Windsurf project rules
# .codeium/          — Codeium/Windsurf workspace config
.windsurfrules
.codeium/

# --- Aider ---
# .aider.conf.yml    — Aider configuration
# .aiderignore       — Aider-specific ignore list (separate from .gitignore)
.aider.conf.yml
.aiderignore
.aider.tags.cache.v*/

# --- OpenAI Codex ---
# CODEX.md           — Codex project instructions  (→ use AGENTS.md)
# .codex/            — Codex local config
CODEX.md
.codex/

# --- Google Gemini ---
# GEMINI.md          — Gemini project instructions  (→ use AGENTS.md)
# .gemini/           — Gemini local config
GEMINI.md
.gemini/

# --- Devin (Cognition) ---
# .devin/            — Devin workspace config
.devin/

# --- Continue ---
# .continue/         — Continue extension config
.continue/

# --- Qodo (CodiumAI) ---
# .qodo/             — Qodo workspace config
.qodo/

# --- mise (dev tooling manager) ---
# ~/.mise/ lives in $HOME; .mise/ could contain local overrides or tool state.
.mise/

# --- pi (the host runtime for this extension) ---
# ~/.pi/ lives in $HOME and is never in the repo, but guard against accidental
# local overrides being committed.
.pi/
